      "get": {
        "tags": [
          "GraphSettings"
        ],
        "summary": "Gets Microsoft Graph settings with masked secret.",
        "responses": {
          "200": {
            "description": "Graph settings found. Example: {\"instance\":\"https://login.microsoftonline.com/\",\"clientSecretMasked\":\"******cret\"}",
