    "/api/health/graph": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Validates Microsoft Graph connectivity against a mailbox target.",
        "parameters": [
          {
            "name": "userMail",
            "in": "query",
            "description": "Optional user mail. If omitted, the first configured company mailbox is used.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mailboxId",
            "in": "query",
            "description": "Optional mailbox id. If omitted, the first configured company mailbox is used.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Connectivity check succeeded.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/GraphConnectivityHealthResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GraphConnectivityHealthResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/GraphConnectivityHealthResponse"
                }
              }
            }
          },
          "503": {
            "description": "Connectivity check failed or no mailbox target is configured.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/GraphConnectivityHealthResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GraphConnectivityHealthResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/GraphConnectivityHealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/reports/export": {
      "get": {
        "tags": [
          "Reports"
        ],
        "summary": "Exporta estadísticas de correo a un archivo Excel.",
        "parameters": [
          {
            "name": "From",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "To",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "Company",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Processed",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Archivo Excel generado correctamente.",
            "content": {
              "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Rango de fechas inválido. Ejemplo: {\"errors\":{\"to\":[\"'to' must be greater than or equal to 'from'.\"]}}",
            "content": {
              "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    },
