    "/api/email-statistics": {
      "get": {
        "tags": [
          "EmailStatistics"
        ],
        "summary": "Obtiene estadísticas de procesamiento de correos con filtros opcionales.",
        "parameters": [
          {
            "name": "From",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "To",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "Company",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Processed",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de estadísticas filtrada. Ejemplo: [{\"date\":\"2026-03-20T09:30:00Z\",\"company\":\"Contoso\",\"processed\":true,\"subject\":\"Factura Marzo\"}]",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EmailStatisticsItemResponse"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EmailStatisticsItemResponse"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EmailStatisticsItemResponse"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Rango de fechas inválido. Ejemplo: {\"errors\":{\"to\":[\"'to' must be greater than or equal to 'from'.\"]}}",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    },
