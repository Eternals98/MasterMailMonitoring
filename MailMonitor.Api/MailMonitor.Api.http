@MailMonitor.Api_HostAddress = http://localhost:5146
@json = application/json
@existingCompanyId = 11111111-1111-1111-1111-111111111111
@missingCompanyId = 00000000-0000-0000-0000-000000000000
@existingTriggerId = 22222222-2222-2222-2222-222222222222
@missingTriggerId = 00000000-0000-0000-0000-000000000000

### SETTINGS - SUCCESS (200)
GET {{MailMonitor.Api_HostAddress}}/api/settings
Accept: {{json}}

### SETTINGS - SUCCESS (204)
PUT {{MailMonitor.Api_HostAddress}}/api/settings
Content-Type: {{json}}

{
  "baseStorageFolder": "C:\\MailMonitor\\Storage"
}

### SETTINGS - ERROR (400)
PUT {{MailMonitor.Api_HostAddress}}/api/settings
Content-Type: {{json}}

{
  "baseStorageFolder": ""
}

### GRAPH SETTINGS - SUCCESS (200)
GET {{MailMonitor.Api_HostAddress}}/api/graph-settings
Accept: {{json}}

### GRAPH SETTINGS - SUCCESS (204)
PUT {{MailMonitor.Api_HostAddress}}/api/graph-settings
Content-Type: {{json}}

{
  "instance": "https://login.microsoftonline.com/",
  "clientId": "11111111-2222-3333-4444-555555555555",
  "tenantId": "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee",
  "clientSecret": "super-secret-value",
  "graphUserScopesJson": "[\"Mail.Read\",\"Mail.ReadWrite\"]"
}

### GRAPH SETTINGS - ERROR (400 invalid JSON)
PUT {{MailMonitor.Api_HostAddress}}/api/graph-settings
Content-Type: {{json}}

{
  "instance": "https://login.microsoftonline.com/",
  "clientId": "11111111-2222-3333-4444-555555555555",
  "tenantId": "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee",
  "clientSecret": "super-secret-value",
  "graphUserScopesJson": "{invalid-json}"
}

### COMPANIES - SUCCESS (200 list, filters name/mail contains)
GET {{MailMonitor.Api_HostAddress}}/api/companies?name=contoso&mail=tenant.com
Accept: {{json}}

### COMPANIES - SUCCESS (201 create)
POST {{MailMonitor.Api_HostAddress}}/api/companies
Content-Type: {{json}}

{
  "name": "Contoso",
  "mail": "contoso@tenant.com",
  "startFrom": "2026-03-01T00:00:00Z",
  "mailBox": ["Inbox", "Facturas"],
  "fileTypes": ["pdf", "xml"],
  "attachmentKeywords": ["factura", "invoice"],
  "storageFolder": "C:\\MailMonitor\\Contoso",
  "reportOutputFolder": "C:\\MailMonitor\\Reports",
  "processingTag": "ONBASE"
}

### COMPANIES - ERROR (400 create invalid payload)
POST {{MailMonitor.Api_HostAddress}}/api/companies
Content-Type: {{json}}

{
  "name": "",
  "mail": "",
  "storageFolder": "",
  "reportOutputFolder": "",
  "processingTag": ""
}

### COMPANIES - SUCCESS (200 get by id)
GET {{MailMonitor.Api_HostAddress}}/api/companies/{{existingCompanyId}}
Accept: {{json}}

### COMPANIES - ERROR (404 get by id)
GET {{MailMonitor.Api_HostAddress}}/api/companies/{{missingCompanyId}}
Accept: {{json}}

### COMPANIES - SUCCESS (204 update)
PUT {{MailMonitor.Api_HostAddress}}/api/companies/{{existingCompanyId}}
Content-Type: {{json}}

{
  "id": "{{existingCompanyId}}",
  "name": "Contoso Updated",
  "mail": "contoso-updated@tenant.com",
  "startFrom": "2026-03-01T00:00:00Z",
  "mailBox": ["Inbox"],
  "fileTypes": ["pdf"],
  "attachmentKeywords": ["factura"],
  "storageFolder": "C:\\MailMonitor\\Contoso",
  "reportOutputFolder": "C:\\MailMonitor\\Reports",
  "processingTag": "ONBASE"
}

### COMPANIES - ERROR (400 id mismatch)
PUT {{MailMonitor.Api_HostAddress}}/api/companies/aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa
Content-Type: {{json}}

{
  "id": "bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb",
  "name": "Contoso",
  "mail": "contoso@tenant.com",
  "startFrom": "2026-03-01T00:00:00Z",
  "mailBox": ["Inbox"],
  "fileTypes": ["pdf"],
  "attachmentKeywords": ["factura"],
  "storageFolder": "C:\\MailMonitor\\Contoso",
  "reportOutputFolder": "C:\\MailMonitor\\Reports",
  "processingTag": "ONBASE"
}

### COMPANIES - ERROR (404 update)
PUT {{MailMonitor.Api_HostAddress}}/api/companies/{{missingCompanyId}}
Content-Type: {{json}}

{
  "id": "{{missingCompanyId}}",
  "name": "Not Found",
  "mail": "none@tenant.com",
  "startFrom": "2026-03-01T00:00:00Z",
  "mailBox": ["Inbox"],
  "fileTypes": ["pdf"],
  "attachmentKeywords": ["none"],
  "storageFolder": "C:\\MailMonitor\\None",
  "reportOutputFolder": "C:\\MailMonitor\\Reports",
  "processingTag": "ONBASE"
}

### COMPANIES - SUCCESS (204 delete)
DELETE {{MailMonitor.Api_HostAddress}}/api/companies/{{existingCompanyId}}

### COMPANIES - ERROR (404 delete)
DELETE {{MailMonitor.Api_HostAddress}}/api/companies/{{missingCompanyId}}

### TRIGGERS - SUCCESS (200 list)
GET {{MailMonitor.Api_HostAddress}}/api/triggers
Accept: {{json}}

### TRIGGERS - SUCCESS (201 create)
POST {{MailMonitor.Api_HostAddress}}/api/triggers
Content-Type: {{json}}

{
  "name": "Daily Report",
  "cronExpression": "0 0 * * *"
}

### TRIGGERS - ERROR (400 invalid cron)
POST {{MailMonitor.Api_HostAddress}}/api/triggers
Content-Type: {{json}}

{
  "name": "Broken Trigger",
  "cronExpression": "invalid-cron"
}

### TRIGGERS - SUCCESS (200 get by id)
GET {{MailMonitor.Api_HostAddress}}/api/triggers/{{existingTriggerId}}
Accept: {{json}}

### TRIGGERS - ERROR (404 get by id)
GET {{MailMonitor.Api_HostAddress}}/api/triggers/{{missingTriggerId}}
Accept: {{json}}

### TRIGGERS - SUCCESS (204 update)
PUT {{MailMonitor.Api_HostAddress}}/api/triggers/{{existingTriggerId}}
Content-Type: {{json}}

{
  "name": "Daily Report Updated",
  "cronExpression": "0 */6 * * *"
}

### TRIGGERS - ERROR (400 update invalid cron)
PUT {{MailMonitor.Api_HostAddress}}/api/triggers/{{existingTriggerId}}
Content-Type: {{json}}

{
  "name": "Broken Trigger",
  "cronExpression": "invalid-cron"
}

### TRIGGERS - ERROR (404 update)
PUT {{MailMonitor.Api_HostAddress}}/api/triggers/{{missingTriggerId}}
Content-Type: {{json}}

{
  "name": "Missing Trigger",
  "cronExpression": "0 */6 * * *"
}

### TRIGGERS - SUCCESS (204 delete)
DELETE {{MailMonitor.Api_HostAddress}}/api/triggers/{{existingTriggerId}}

### TRIGGERS - ERROR (404 delete)
DELETE {{MailMonitor.Api_HostAddress}}/api/triggers/{{missingTriggerId}}

### EMAIL STATISTICS - SUCCESS (200 filters + desc date)
GET {{MailMonitor.Api_HostAddress}}/api/email-statistics?from=2026-03-01T00:00:00Z&to=2026-03-31T23:59:59Z&company=contoso&processed=true
Accept: {{json}}

### EMAIL STATISTICS - ERROR (400 invalid range)
GET {{MailMonitor.Api_HostAddress}}/api/email-statistics?from=2026-03-31T23:59:59Z&to=2026-03-01T00:00:00Z
Accept: {{json}}

### REPORT EXPORT - SUCCESS (200 Excel)
GET {{MailMonitor.Api_HostAddress}}/api/reports/export?from=2026-03-01T00:00:00Z&to=2026-03-31T23:59:59Z&company=contoso&processed=true
Accept: application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

### REPORT EXPORT - ERROR (400 invalid range)
GET {{MailMonitor.Api_HostAddress}}/api/reports/export?from=2026-03-31T23:59:59Z&to=2026-03-01T00:00:00Z
Accept: {{json}}
