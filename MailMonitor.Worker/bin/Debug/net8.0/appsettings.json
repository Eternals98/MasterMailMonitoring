{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Persistence": {
    "ConfigurationDbPath": "mailmonitor.db"
  },
  "Scheduling": {
    "TimeZoneId": "America/New_York",
    "FallbackCronExpression": "0 0/10 * ? * * *"
  },
  "Storage": {
    "MaxRetries": 3,
    "BaseDelayMilliseconds": 300,
    "MaxDelayMilliseconds": 4000
  },
  "Graph": {
    "Instance": "https://login.microsoftonline.com/",
    "ClientId": "",
    "TenantId": "",
    "ClientSecret": "",
    "Scopes": [
      "https://graph.microsoft.com/.default"
    ]
  }
}
