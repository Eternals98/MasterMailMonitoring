VITE_API_BASE_URL=http://localhost:5146/api
VITE_AUTH_USERNAME=admin
VITE_AUTH_PASSWORD=mailmonitor123

# Mini guia:
# 1) Copia este archivo a .env en MailMonitor.Web
# 2) Ajusta VITE_API_BASE_URL a la URL publica de tu API (sin slash final)
# 3) Configura VITE_AUTH_USERNAME / VITE_AUTH_PASSWORD para login local
# 4) Reinicia npm run dev para tomar cambios
