VITE_API_BASE_URL=https://mailmonitor-api-qa.example.com/api
VITE_AUTH_USERNAME=admin
VITE_AUTH_PASSWORD=change-me-qa

# Mini guia QA:
# 1) Copia este archivo a .env en MailMonitor.Web
# 2) Ajusta VITE_API_BASE_URL a la URL real de API QA (sin slash final)
# 3) Cambia credenciales locales de acceso UI
# 4) Reinicia npm run dev para tomar cambios
