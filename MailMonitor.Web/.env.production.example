VITE_API_BASE_URL=https://mailmonitor-api.example.com/api
VITE_AUTH_USERNAME=admin
VITE_AUTH_PASSWORD=change-me-prod

# Mini guia Production:
# 1) Copia este archivo a .env en MailMonitor.Web (host de despliegue)
# 2) Ajusta VITE_API_BASE_URL a la URL real de API Production (sin slash final)
# 3) Cambia credenciales locales de acceso UI
# 4) Reconstruye/reinicia el frontend para tomar cambios
